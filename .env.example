# Configuración de Entorno - Imbra Store Headless

# URL de tu tienda WordPress/WooCommerce
NEXT_PUBLIC_WORDPRESS_URL=https://tu-sitio-wordpress.com

# Credenciales de API de WooCommerce (Generar en WooCommerce -> Ajustes -> Avanzado -> REST API)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Otras configuraciones
NODE_ENV=development
PORT=3000
